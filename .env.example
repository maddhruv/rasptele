# Obtain this from @BotFather. Never commit a real token.
TELEGRAM_BOT_TOKEN=
# Numeric Telegram user ID; only this account can use the bot.
TELEGRAM_ALLOWED_USER_ID=

# Optional Pi-hole v6 integration. Set both values or leave both empty.
PIHOLE_URL=
PIHOLE_PASSWORD=

# Optional operational settings. Values below are the defaults.
RASPTELE_RESTART_ALLOWED=
RASPTELE_MONITOR_INTERVAL_SECONDS=60
RASPTELE_REMINDER_INTERVAL_MINUTES=30
RASPTELE_AUDIT_RETENTION_DAYS=90
RASPTELE_DISK_PERCENT=90
RASPTELE_TEMPERATURE_CELSIUS=80

{
  "$schema": "https://unpkg.com/release-it@20/schema/release-it.json",
  "hooks": {
    "after:bump": "python -m unittest discover -s tests -v"
  },
  "git": {
    "requireBranch": "main",
    "commitMessage": "chore: release v${version}",
    "tagName": "v${version}",
    "tagAnnotation": "Rasptele ${version}",
    "pushArgs": ["--follow-tags"]
  },
  "github": {
    "release": true,
    "releaseName": "Rasptele ${version}",
    "draft": true
  },
  "npm": {
    "publish": false
  },
  "plugins": {
    "@release-it/bumper": {
      "in": {
        "file": "pyproject.toml",
        "path": "project.version"
      },
      "out": [
        {
          "file": "pyproject.toml",
          "path": "project.version"
        },
        {
          "file": "src/rasptele/__init__.py",
          "type": "text/plain"
        },
        {
          "file": "compose.yaml",
          "type": "text/plain"
        },
        {
          "file": "compose.coolify.yaml",
          "type": "text/plain"
        },
        {
          "file": "compose.portainer.yaml",
          "type": "text/plain"
        }
      ]
    },
    "@release-it/keep-a-changelog": {
      "filename": "CHANGELOG.md",
      "addUnreleased": true,
      "addVersionUrl": true,
      "head": "HEAD"
    }
  }
}
